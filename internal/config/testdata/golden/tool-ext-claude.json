{
  "type": "sandbox",
  "name": "claude",
  "description": "Claude Code AI assistant",
  "default_included": true,
  "priority": 100,
  "secrets": {
    "anthropic-api-key": {
      "env_vars": [
        "ANTHROPIC_API_KEY"
      ],
      "release": {
        "http": {
          "hosts": [
            "*.anthropic.com",
            "api.anthropic.com"
          ],
          "header": "x-api-key"
        }
      }
    },
    "claude-code-oauth-token": {
      "env_vars": [
        "CLAUDE_CODE_OAUTH_TOKEN"
      ],
      "api_key": false
    }
  }
}
