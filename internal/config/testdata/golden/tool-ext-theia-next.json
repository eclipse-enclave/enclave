{
  "type": "sandbox",
  "name": "theia-next",
  "description": "Theia Next (preview) desktop IDE attached to an enclave container",
  "default_included": true,
  "priority": 100,
  "secrets": {
    "anthropic-api-key": {
      "env_vars": [
        "ANTHROPIC_API_KEY"
      ],
      "release": {
        "http": {
          "hosts": [
            "*.anthropic.com",
            "api.anthropic.com"
          ],
          "header": "x-api-key"
        }
      }
    }
  }
}
