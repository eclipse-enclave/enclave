{
  "name": "claude",
  "command": "claude",
  "continue_args": [
    "--continue"
  ],
  "resume_args": [
    "--resume"
  ],
  "yolo_flag": "--dangerously-skip-permissions",
  "yolo_enabled": true,
  "config_dir": ".claude",
  "skills_dir": ".claude/skills",
  "memory_dir": ".claude/memory",
  "settings_file": "claude-settings.json",
  "settings_target": ".claude/settings.json",
  "passthrough_paths": [
    "agents/",
    "commands/",
    "settings.json",
    "skills/"
  ],
  "qemu_min_memory_mib": 4096,
  "providers": [
    {
      "name": "anthropic",
      "credential_secrets": [
        "anthropic-api-key",
        "claude-code-oauth-token"
      ],
      "auth_files": [
        "config.json",
        ".credentials.json"
      ],
      "auth_session": {
        "mode": "any",
        "checks": [
          {
            "file": "config.json",
            "type": "file_exists"
          },
          {
            "file": ".credentials.json",
            "type": "file_exists"
          }
        ]
      },
      "securestorage_dir_env": "CLAUDE_SECURESTORAGE_CONFIG_DIR"
    }
  ],
  "secrets": {
    "anthropic-api-key": {
      "env_vars": [
        "ANTHROPIC_API_KEY"
      ],
      "release": {
        "http": {
          "hosts": [
            "*.anthropic.com",
            "api.anthropic.com"
          ],
          "header": "x-api-key"
        }
      }
    },
    "claude-code-oauth-token": {
      "env_vars": [
        "CLAUDE_CODE_OAUTH_TOKEN"
      ],
      "api_key": false
    }
  },
  "host_config_dir": ".claude",
  "host_credentials_file": ".credentials.json",
  "host_oauth_json": ".claude.json"
}
